    {
      "rule": "Maintain a tight, intentional core site. Aim for a concise set of evergreen pages (approximately 30–50). Prioritise depth of content quality over breadth.",
      "ruleStrength": "SHOULD",
      "status": "Approved",
      "type": "Design principle",
