    {
      "rule": "Prefer vertical depth over horizontal complexity. Scrolling preserves context. Clicking breaks it. Build long, structured pages rather than spreading content across many shallow destinations.",
      "ruleStrength": "SHOULD",
      "status": "Proposal",
      "type": "Design principle",
