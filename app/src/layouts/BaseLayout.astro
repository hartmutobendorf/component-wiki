---
import '../styles/page.scss';
import { getCollection } from 'astro:content';

interface Props {
  title?: string;
  currentSlug?: string;
}

const { title = 'Component Wiki', currentSlug = '' } = Astro.props;

// Get all components from the collection
const components = await getCollection('components');

// Create nav items
const navItems = components.map(component => ({
  name: component.data.name,
  slug: component.id
}));
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <header class="p-navigation is-sticky mobile-header">
      <div class="p-navigation__row">
        <div class="p-navigation__banner">
          <div class="p-navigation__tagged-logo">
            <a class="p-navigation__link" href="/">
              Component Wiki
            </a>
          </div>
        </div>
      </div>
    </header>

    <div class="l-site">
      <aside class="l-site-nav">
        <side-navigation
          nav-items={JSON.stringify(navItems)}
          current-slug={currentSlug}
        ></side-navigation>
      </aside>

      <main class="l-site-main">
        <div class="p-strip is-shallow">
          <div class="row">
            <div class="col-12">
              <slot />
            </div>
          </div>
        </div>
      </main>
    </div>

    <script>
      // Import the side-navigation web component
      import '../components/sideNavigation/side-navigation.js';
    </script>
  </body>
</html>
