---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// Generate paths for all components
export async function getStaticPaths() {
  const components = await getCollection('components');

  return components.map((component: any) => ({
    params: { slug: component.id },
    props: { componentId: component.id }
  }));
}

const { componentId } = Astro.props;

// Get component metadata
const component = await getEntry('components', componentId);
const metadata = component.data;

// Import markdown files using glob
const markdownModules = import.meta.glob('../content/md/*/*.md');

// Helper to load and render markdown
async function loadMarkdownSection(section: string) {
  const path = `../content/md/${componentId}/${section}.md`;
  const module = markdownModules[path];

  if (!module) {
    return { hasContent: false, Content: null };
  }

  try {
    const loaded = await module();
    return {
      hasContent: true,
      Content: (loaded as any).default || (loaded as any).Content
    };
  } catch (error) {
    console.error(`Error loading ${section}:`, error);
    return { hasContent: false, Content: null };
  }
}

const description = await loadMarkdownSection('description');
const usage = await loadMarkdownSection('usage');
const anatomy = await loadMarkdownSection('anatomy');
const examples = await loadMarkdownSection('examples');
---

<BaseLayout title={`${metadata.name} - Component Wiki`} currentSlug={componentId}>
  <h1 slot="title">{metadata.name}</h1>

  <div slot="meta" class="p-table-of-contents">
    <div class="p-table-of-contents__section">
      <h2 class="p-table-of-contents__header">On this page</h2>
      <ul class="p-table-of-contents__list">
        <li class="p-table-of-contents__item">
          <a class="p-table-of-contents__link" href="#metadata">Metadata</a>
        </li>
        {description.hasContent && (
          <li class="p-table-of-contents__item">
            <a class="p-table-of-contents__link" href="#description">Description</a>
          </li>
        )}
        {anatomy.hasContent && (
          <li class="p-table-of-contents__item">
            <a class="p-table-of-contents__link" href="#anatomy">Anatomy</a>
          </li>
        )}
        {usage.hasContent && (
          <li class="p-table-of-contents__item">
            <a class="p-table-of-contents__link" href="#usage">Usage</a>
          </li>
        )}
        {examples.hasContent && (
          <li class="p-table-of-contents__item">
            <a class="p-table-of-contents__link" href="#examples">Examples</a>
          </li>
        )}
      </ul>
    </div>
  </div>

  <div class="p-card metadata-card" id="metadata">
    <div class="p-card__content">
      <dl class="metadata-list">
        <dt>Type</dt>
        <dd>{metadata.type}</dd>

        <dt>Tier</dt>
        <dd>{metadata.tiers}</dd>

        <dt>Documentation Status</dt>
        <dd>{metadata.documentationStatus}</dd>

        <dt>Last Edited</dt>
        <dd>{metadata.lastEdited}</dd>

        {metadata.figmaLink && (
          <>
            <dt>Figma</dt>
            <dd>
              <a href={metadata.figmaLink} target="_blank" rel="noopener noreferrer">
                View in Figma
              </a>
            </dd>
          </>
        )}

        {metadata.codeLink && (
          <>
            <dt>Code</dt>
            <dd>
              <a href={metadata.codeLink} target="_blank" rel="noopener noreferrer">
                View Code
              </a>
            </dd>
          </>
        )}
      </dl>
    </div>
  </div>

  {description.hasContent && description.Content && (
    <section id="description" class="u-text-max-width">
      <description.Content />
    </section>
  )}

  {anatomy.hasContent && anatomy.Content && (
    <section id="anatomy" class="u-text-max-width">
      <h2>Anatomy</h2>
      <anatomy.Content />
    </section>
  )}

  {usage.hasContent && usage.Content && (
    <section id="usage" class="u-text-max-width">
      <h2>Usage</h2>
      <usage.Content />
    </section>
  )}

  {examples.hasContent && examples.Content && (
    <section id="examples" class="u-text-max-width">
      <h2>Examples</h2>
      <examples.Content />
    </section>
  )}
</BaseLayout>
