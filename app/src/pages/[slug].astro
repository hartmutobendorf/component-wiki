---
import { getCollection, getEntry } from "astro:content";
import CopyFigmaButton from "../components/CopyFigmaButton.astro";
import FigmaLink from "../components/FigmaLink.astro";
import GithubLink from "../components/GithubLink.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

// Generate paths for all components
export async function getStaticPaths() {
  const components = await getCollection("components");

  return components.map((component: any) => ({
    params: { slug: component.id },
    props: { componentId: component.id },
  }));
}

const { componentId } = Astro.props;

// Get component metadata
const component = await getEntry("components", componentId);
const metadata = component.data;

// Import markdown files using glob
const markdownModules = import.meta.glob("../content/md/*/*.md");

// Helper to load and render markdown
async function loadMarkdownSection(section: string) {
  const path = `../content/md/${componentId}/${section}.md`;
  const module = markdownModules[path];

  if (!module) {
    return { hasContent: false, Content: null };
  }

  try {
    const loaded = await module();
    return {
      hasContent: true,
      Content: (loaded as any).default || (loaded as any).Content,
    };
  } catch (error) {
    console.error(`Error loading ${section}:`, error);
    return { hasContent: false, Content: null };
  }
}

const description = await loadMarkdownSection("description");
const usage = await loadMarkdownSection("usage");
const anatomy = await loadMarkdownSection("anatomy");
const examples = await loadMarkdownSection("examples");
---

<BaseLayout
  title={`${metadata.name} - Component Wiki`}
  currentSlug={componentId}
>
  <div slot="meta" class="p-table-of-contents">
    <div class="p-table-of-contents__section">
      <h2 class="p-table-of-contents__header">On this page</h2>
      <ul class="p-table-of-contents__list">
        <li class="p-table-of-contents__item">
          <a class="p-table-of-contents__link" href="#metadata">Metadata</a>
        </li>
        {
          description.hasContent && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#description">
                Description
              </a>
            </li>
          )
        }
        {
          anatomy.hasContent && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#anatomy">
                Anatomy
              </a>
            </li>
          )
        }
        {
          usage.hasContent && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#usage">
                Usage
              </a>
            </li>
          )
        }
        {
          examples.hasContent && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#examples">
                Examples
              </a>
            </li>
          )
        }
      </ul>
    </div>
  </div>

  <div class="l-docs__title">
    <div class="p-strip is-shallow u-no-padding--bottom">
      <div class="u-fixed-width">
        <h1>{metadata.name}</h1>
      </div>
    </div>
  </div>

  <div class="row--50-50 p-section">
    <div class="col">
      {
        metadata.componentExampleImage ? (
          <img
            src={`/${metadata.componentExampleImage}`}
            alt={`${metadata.name} example`}
            style="width: 100%; height: 500px; object-fit: contain; background-color: #F7F7F7;"
          />
        ) : (
          <div style="width: 100%; height: 500px; background-color: #F7F7F7;" />
        )
      }
    </div>

    <div class="col">
      {
        description.hasContent && description.Content && (
          <section id="description" class="u-text-max-width">
            <description.Content />

            <div class="metadata-list">
              <div class="metadata-item">
                <span class="metadata-key p-text--small-caps u-text--muted">
                  Type
                </span>
                <span class="metadata-value">{metadata.type}</span>
              </div>

              <div class="metadata-item">
                <span class="metadata-key p-text--small-caps u-text--muted">
                  Tier
                </span>
                <span class="metadata-value">{metadata.tiers}</span>
              </div>

              <div class="metadata-item">
                <span class="metadata-key p-text--small-caps u-text--muted">
                  Documentation Status
                </span>
                <span class="metadata-value">
                  {metadata.documentationStatus}
                </span>
              </div>

              <div class="metadata-item">
                <span class="metadata-key p-text--small-caps u-text--muted">
                  Last Edited
                </span>
                <span class="metadata-value">{metadata.lastEdited}</span>
              </div>

              <div class="metadata-chips">
                {metadata.figmaLink && <FigmaLink href={metadata.figmaLink} />}
                {metadata.codeLink && <GithubLink href={metadata.codeLink} />}
              </div>

              {metadata.figmaComponentDataPath && (
                <CopyFigmaButton
                  dataPath={`/${metadata.figmaComponentDataPath}`}
                  textContent={metadata.name}
                />
              )}
            </div>
          </section>
        )
      }
    </div>
  </div>

  <div class="row--50-50 p-section">
    <div class="col">
      {
        anatomy.hasContent && anatomy.Content && (
          <section id="anatomy" class="u-text-max-width">
            <h2>Anatomy</h2>
            <anatomy.Content />
          </section>
        )
      }

      {
        usage.hasContent && usage.Content && (
          <section id="usage" class="u-text-max-width">
            <h2>Usage</h2>
            <usage.Content />
          </section>
        )
      }

      {
        examples.hasContent && examples.Content && (
          <section id="examples" class="u-text-max-width">
            <h2>Examples</h2>
            <examples.Content />
          </section>
        )
      }
    </div>

    <div class="col"></div>
  </div>

  <style>
    .metadata-list {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem 2rem;
      align-items: center;
    }

    .metadata-item {
      display: flex;
      flex-direction: column;
    }

    .metadata-key {
      margin: 0;
    }

    .metadata-value {
      margin: 0;
    }

    .metadata-chips {
      display: flex;
      gap: 1.5rem;
      align-items: center;
    }
  </style>
</BaseLayout>
