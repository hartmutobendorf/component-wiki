# GitHub Webhook Secret
# Generate a secure random string for webhook authentication
# You can generate one using: openssl rand -hex 32
WEBHOOK_SECRET=your-secret-token-here

# GitHub Personal Access Token (PAT)
# Create a PAT at https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos)
# This is used to authenticate git pull operations in the webhook deployment
GITHUB_PAT=your-github-pat-here

# GitHub Repository URL
# The repository to pull from when webhook is triggered
GITHUB_REPO=https://github.com/dgtlntv/component-wiki.git

# Domain Configuration
# Main domain for the markdown server application
MAIN_DOMAIN=example.com

# Webhook subdomain
WEBHOOK_DOMAIN=webhook.example.com

# Port Configuration
# External HTTP port (default: 80)
HTTP_PORT=80

# External HTTPS port (default: 443)
HTTPS_PORT=443

# Internal service ports
# Webhook service internal port (default: 9000)
WEBHOOK_INTERNAL_PORT=9000

# Markdown server internal port (default: 8000)
MARKDOWN_SERVER_INTERNAL_PORT=8000

# Container user/group IDs
PUID=1000
PGID=1000

# Timezone
TZ=Etc/UTC
