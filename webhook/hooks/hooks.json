[
    {
        "id": "redeploy-markdown-server",
        "execute-command": "/config/deploy.sh",
        "command-working-directory": "/config",
        "response-message": "Analyzing changes and deploying...",
        "response-headers": [
            {
                "name": "Access-Control-Allow-Origin",
                "value": "*"
            }
        ],
        "trigger-rule": {
            "and": [
                {
                    "match": {
                        "type": "payload-hmac-sha256",
                        "secret": "{{ getenv "WEBHOOK_SECRET" }}",
                        "parameter": {
                            "source": "header",
                            "name": "X-Hub-Signature-256"
                        }
                    }
                },
                {
                    "match": {
                        "type": "value",
                        "value": "refs/heads/main",
                        "parameter": {
                            "source": "payload",
                            "name": "ref"
                        }
                    }
                }
            ]
        },
        "pass-arguments-to-command": [
            {
                "source": "payload",
                "name": "head_commit.id"
            },
            {
                "source": "payload",
                "name": "pusher.name"
            },
            {
                "source": "entire-payload"
            }
        ]
    }
]
