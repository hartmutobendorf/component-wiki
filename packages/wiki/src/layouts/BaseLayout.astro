---
import "../styles/page.scss";
import { getCollection } from "astro:content";
import { ClientRouter } from "astro:transitions";
import TopNavigation from "../components/TopNavigation.astro";
import { buildNavData, type NavData } from "../utils/nav-data";

interface Props {
  title?: string;
  currentSlug?: string;
  activeTier?: string;
  /** Pre-built navigation data. When omitted, collections are fetched here. */
  navData?: NavData;
}

const { title = "Component Wiki", currentSlug = "", activeTier = "Global", navData: providedNavData } = Astro.props;

// Use pre-built navData when the caller already has the collection data,
// otherwise fetch here as a fallback (e.g. 404 page).
let navData: NavData;
if (providedNavData) {
  navData = providedNavData;
} else {
  const allConstructs = await getCollection("constructs");
  const allConcepts = await getCollection("concepts");
  navData = buildNavData(activeTier, allConstructs, allConcepts);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon.png" />
    <ClientRouter />
  </head>
  <body>
    <div class="l-docs">
      <div class="l-docs__header">
        <TopNavigation activeTier={activeTier} />
      </div>

      <aside class="l-docs__sidebar">
        <script
          id="nav-data"
          type="application/json"
          set:html={JSON.stringify(navData)}
        />
        <side-navigation
          nav-data={JSON.stringify(navData)}
          current-slug={currentSlug}
          transition:persist></side-navigation>
      </aside>

      <div class="l-docs__meta">
        <div class="l-docs__sticky-container p-strip is-shallow">
          <slot name="meta" />
        </div>
      </div>

      <main class="l-docs__main">
        <div class="p-section">
          <div class="u-fixed-width">
            <slot />
          </div>
        </div>
      </main>
    </div>

    <script>
      import "../components/sideNavigation/side-navigation.ts";
      import "../scripts/side-nav-sync.ts";
    </script>
  </body>
</html>
