---
import RuleStrengthChip from "./RuleStrengthChip.astro";
import { renderInlineMarkdown } from "../utils/render-markdown";

interface Rule {
  rule: string;
  ruleStrength: string;
  status: string;
  type: string;
  knownExceptionForConstructs: string;
}

interface Props {
  ruleType: string;
  rules: Rule[];
}

const { ruleType, rules } = Astro.props;
---

<h3>{ruleType}</h3>
<table aria-label={`${ruleType} rules`}>
  <thead>
    <tr>
      <th style="width: 60%">Rule</th>
      <th style="width: 15%">Strength</th>
      <th style="width: 25%">Known exceptions</th>
    </tr>
  </thead>
  <tbody>
    {rules.map((rule) => (
      <tr>
        <td><Fragment set:html={renderInlineMarkdown(rule.rule)} /></td>
        <td>
          <RuleStrengthChip strength={rule.ruleStrength} />
        </td>
        <td><Fragment set:html={renderInlineMarkdown(rule.knownExceptionForConstructs) || "—"} /></td>
      </tr>
    ))}
  </tbody>
</table>
