---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import MetadataBlock from "./MetadataBlock.astro";
import ChangeLogTable from "./ChangeLogTable.astro";
import DecisionLogTable from "./DecisionLogTable.astro";
import MentionedInList from "./MentionedInList.astro";
import RulesTable from "./RulesTable.astro";
import { renderMarkdown, type OptimizedImageInfo } from "../utils/render-markdown";
import { tierToPrefix, buildConceptPath } from "../utils/tiers";
import { collectMarkdownImages } from "../utils/collect-markdown-images";
import { getImage } from "astro:assets";

interface Props {
  conceptId: string;
  activeTier: string;
}

const { conceptId, activeTier } = Astro.props;

const tierPrefix = tierToPrefix(activeTier);

// Get concept metadata
const concept = await getEntry("concepts", conceptId);
if (!concept) {
  return Astro.redirect("/404");
}
const metadata = concept.data;

// Build optimized image map for markdown images.
// See ConstructPage.astro for detailed explanation of why this is needed.
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "/../../data/raw/images/*.{png,jpg,jpeg,gif,svg,webp}",
  { eager: true },
);
const imageFilenameMap = new Map<string, ImageMetadata>();
for (const [path, mod] of Object.entries(allImages)) {
  imageFilenameMap.set(path.split("/").pop()!, mod.default);
}

const markdownImagePaths = collectMarkdownImages(
  metadata.description,
  metadata.content,
);

const imageMap = new Map<string, OptimizedImageInfo>();
for (const imgPath of markdownImagePaths) {
  const filename = imgPath.split("/").pop()!;
  const imageMeta = imageFilenameMap.get(filename);
  if (imageMeta) {
    const optimized = await getImage({ src: imageMeta });
    imageMap.set(imgPath, {
      src: optimized.src,
      width: optimized.attributes.width as number,
      height: optimized.attributes.height as number,
    });
  }
}

// Render markdown sections with optimized image URLs
const descriptionHtml = renderMarkdown(metadata.description, imageMap);
const contentHtml = renderMarkdown(metadata.content, imageMap);

const hasDescription = descriptionHtml.length > 0;
const hasContent = contentHtml.length > 0;

// Group applied rules by type
const rulesByType = new Map<string, typeof metadata.appliedRules>();
for (const rule of metadata.appliedRules ?? []) {
  const type = rule.type || "Other";
  if (!rulesByType.has(type)) {
    rulesByType.set(type, []);
  }
  rulesByType.get(type)!.push(rule);
}
const sortedRuleTypes = [...rulesByType.keys()].sort();
---

<BaseLayout
  title={`${metadata.name} - Component Wiki`}
  currentSlug={buildConceptPath(activeTier, conceptId)}
  activeTier={activeTier}
>
  <div slot="meta">
    <div class="wiki-llm-button-wrapper">
      <llm-button component-id={conceptId} />
    </div>
    <div class="p-table-of-contents">
    <div class="p-table-of-contents__section">
      <h2 class="p-table-of-contents__header">On this page</h2>
      <ul class="p-table-of-contents__list">
        <li class="p-table-of-contents__item">
          <a class="p-table-of-contents__link" href="#metadata">Metadata</a>
        </li>
        {
          hasDescription && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#description">Description</a>
            </li>
          )
        }
        {
          hasContent && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#content">
                Content
              </a>
            </li>
          )
        }
        {
          metadata.appliedRules && metadata.appliedRules.length > 0 && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#rules">
                Applied rules
              </a>
            </li>
          )
        }
        {
          metadata.changeLog && metadata.changeLog.length > 0 && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#changelog">
                Change log
              </a>
            </li>
          )
        }
        {
          metadata.decisionLog && metadata.decisionLog.length > 0 && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#decisionlog">
                Decision log
              </a>
            </li>
          )
        }
        {
          metadata.mentionedIn && metadata.mentionedIn.length > 0 && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#mentionedin">
                Mentioned in
              </a>
            </li>
          )
        }
        {
          metadata.mentionsComponents && metadata.mentionsComponents.length > 0 && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#mentionscomponents">
                References
              </a>
            </li>
          )
        }
      </ul>
    </div>
  </div>
  </div>

  <div class="l-docs__title">
    <div class="p-strip is-shallow u-no-padding--bottom">
      <div class="u-fixed-width">
        <h1>{metadata.name}</h1>
      </div>
    </div>
  </div>

  <section id="metadata" class="p-section u-text-max-width">
    {
      hasDescription && (
        <div id="description">
          <Fragment set:html={descriptionHtml} />
        </div>
      )
    }

    <MetadataBlock
      type={metadata.type}
      tier={metadata.tier}
      documentationStatus={metadata.documentationStatus}
      lastEdited={metadata.lastEdited}
    />

    <div class="wiki-copy-button-wrapper">
      <copy-markdown-button component-id={conceptId} />
    </div>
  </section>

  {
    hasContent && (
      <section id="content" class="p-section u-text-max-width">
        <h2 id="content"><a href="#content" class="p-link--anchor-heading">Content</a></h2>
        <Fragment set:html={contentHtml} />
      </section>
    )
  }

  {
    metadata.appliedRules && metadata.appliedRules.length > 0 && (
      <section id="rules" class="p-section">
        <h2 id="rules"><a href="#rules" class="p-link--anchor-heading">Applied rules</a></h2>
        {sortedRuleTypes.map((ruleType) => (
          <RulesTable ruleType={ruleType} rules={rulesByType.get(ruleType)!} />
        ))}
      </section>
    )
  }

  <ChangeLogTable entries={metadata.changeLog ?? []} />
  <DecisionLogTable entries={metadata.decisionLog ?? []} />
  <MentionedInList entries={metadata.mentionedIn ?? []} tierPrefix={tierPrefix} />

  {
    metadata.mentionsComponents && metadata.mentionsComponents.length > 0 && (
      <div class="p-section">
        <section id="mentionscomponents" class="u-text-max-width">
          <h2 id="mentionscomponents"><a href="#mentionscomponents" class="p-link--anchor-heading">References</a></h2>
          <p>This concept references the following constructs:</p>
          <ul class="p-list">
            {[...new Map(metadata.mentionsComponents.map((entry) => [entry.slug, entry])).values()].map((entry) => (
              <li class="p-list__item">
                <a href={`/${tierPrefix}/${entry.slug}`}>{entry.name}</a>
              </li>
            ))}
          </ul>
        </section>
      </div>
    )
  }

  <script>
    import "../components/imageLightbox/image-lightbox.ts";
    import "../components/llmButton/llm-button.ts";
    import "../components/copyMarkdownButton/copy-markdown-button.ts";
  </script>
</BaseLayout>
