---
/**
 * OptimizedImage — wraps Astro's <Image /> for images stored outside src/.
 *
 * Images live in data/raw/images/ (written by coda-sync) and are made
 * available to Astro's asset pipeline via the @images Vite alias.
 * This component resolves a relative path like "images/abc.png" to the
 * corresponding ImageMetadata and passes it to <Image />, which
 * generates WebP, sets width/height (preventing CLS), and adds
 * loading="lazy" + decoding="async".
 *
 * See image-map.ts for the shared lookup logic.
 */
import { Image } from "astro:assets";
import { buildImageLookup, resolveImage } from "../utils/image-map";

interface Props {
  /** Image path as stored in JSON data, e.g. "images/abc-123.png" */
  src: string;
  alt: string;
  class?: string;
}

// NOTE: import.meta.glob() must be called here — Vite requires a static
// string literal at the call site; it cannot be moved into a utility.
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "/../../data/raw/images/*.{png,jpg,jpeg,gif,svg,webp}",
  { eager: true },
);
const imageLookup = buildImageLookup(allImages);

const { src, alt, class: className } = Astro.props;
const imageData = resolveImage(src, imageLookup);
---

{
  imageData ? (
    <Image
      src={imageData}
      alt={alt}
      class={className}
      loading="lazy"
      decoding="async"
    />
  ) : (
    <img src={`/${src}`} alt={alt} class={className} loading="lazy" decoding="async" />
  )
}
