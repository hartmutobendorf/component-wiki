---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import MetadataBlock from "./MetadataBlock.astro";
import ChangeLogTable from "./ChangeLogTable.astro";
import DecisionLogTable from "./DecisionLogTable.astro";
import MentionedInList from "./MentionedInList.astro";
import { renderMarkdown, renderInlineMarkdown } from "../utils/render-markdown";
import { tierToPrefix, buildConstructPath } from "../utils/tiers";
import { collectMarkdownImages } from "../utils/collect-markdown-images";
import { buildImageLookup, buildOptimizedImageMap } from "../utils/image-map";
import OptimizedImage from "./OptimizedImage.astro";

interface Props {
  constructId: string;
  activeTier: string;
}

const { constructId, activeTier } = Astro.props;

const tierPrefix = tierToPrefix(activeTier);

// Get construct metadata
const construct = await getEntry("constructs", constructId);
if (!construct) {
  return Astro.redirect("/404");
}
const metadata = construct.data;

// Build optimized image map for markdown images.
// Markdown lives in JSON fields (not .md files), so it bypasses Astro's
// markdown pipeline and its automatic image optimization. We bridge that
// gap by calling getImage() for each referenced image and passing the
// resulting URL map to the markdown renderer. See image-map.ts for details.
// NOTE: import.meta.glob() must be called here — Vite requires a static
// string literal at the call site; it cannot be moved into a utility.
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "/../../data/raw/images/*.{png,jpg,jpeg,gif,svg,webp}",
  { eager: true },
);
const imageLookup = buildImageLookup(allImages);
const markdownImagePaths = collectMarkdownImages(
  metadata.description,
  metadata.usage,
  metadata.examples,
  metadata.interactions,
);
const imageMap = await buildOptimizedImageMap(markdownImagePaths, imageLookup);

// Render markdown sections with optimized image URLs
const descriptionHtml = renderMarkdown(metadata.description, imageMap);
const usageHtml = renderMarkdown(metadata.usage, imageMap);
const examplesHtml = renderMarkdown(metadata.examples, imageMap);
const interactionsHtml = renderMarkdown(metadata.interactions, imageMap);

const hasDescription = descriptionHtml.length > 0;
const hasUsage = usageHtml.length > 0;
const hasExamples = examplesHtml.length > 0;
const hasInteractions = interactionsHtml.length > 0;
---

<BaseLayout
  title={`${metadata.name} - Component Wiki`}
  currentSlug={buildConstructPath(activeTier, constructId)}
  activeTier={activeTier}
>
  <div slot="meta">
    <div class="wiki-llm-button-wrapper">
      <llm-button component-id={constructId} />
    </div>
    <div class="p-table-of-contents">
    <div class="p-table-of-contents__section">
      <h2 class="p-table-of-contents__header">On this page</h2>
      <ul class="p-table-of-contents__list">
        <li class="p-table-of-contents__item">
          <a class="p-table-of-contents__link" href="#metadata">Metadata</a>
        </li>
        {
          hasDescription && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#description">
                Description
              </a>
            </li>
          )
        }
        {
          metadata.anatomy &&
            (metadata.anatomy.image ||
              (metadata.anatomy.table &&
                metadata.anatomy.table.length > 0)) && (
              <li class="p-table-of-contents__item">
                <a class="p-table-of-contents__link" href="#anatomy">
                  Anatomy
                </a>
              </li>
            )
        }
        {
          hasUsage && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#usage">
                Usage
              </a>
            </li>
          )
        }
        {
          hasExamples && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#examples">
                Examples
              </a>
            </li>
          )
        }
        {
          hasInteractions && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#interactions">
                Interactions
              </a>
            </li>
          )
        }
        {
          ((metadata.properties && metadata.properties.length > 0) ||
            (metadata.childProperties &&
              metadata.childProperties.length > 0)) && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#properties">
                Properties
              </a>
            </li>
          )
        }
        {
          metadata.changeLog && metadata.changeLog.length > 0 && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#changelog">
                Change log
              </a>
            </li>
          )
        }
        {
          metadata.decisionLog && metadata.decisionLog.length > 0 && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#decisionlog">
                Decision log
              </a>
            </li>
          )
        }
        {
          metadata.mentionedIn && metadata.mentionedIn.length > 0 && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#mentionedin">
                Mentioned in
              </a>
            </li>
          )
        }
      </ul>
    </div>
  </div>
  </div>

  <div class="l-docs__title">
    <div class="p-strip is-shallow u-no-padding--bottom">
      <div class="u-fixed-width">
        <h1>{metadata.name}</h1>
      </div>
    </div>
  </div>

  <div class="row--50-50 p-section">
    <div class="col">
      {
        hasDescription && (
          <section id="description" class="u-text-max-width">
            <Fragment set:html={descriptionHtml} />

            <MetadataBlock
              type={metadata.type}
              tier={metadata.tiers}
              documentationStatus={metadata.documentationStatus}
              lastEdited={metadata.lastEdited}
              figmaLink={metadata.figmaLink}
              codeLink={metadata.codeLink}
            >
              {metadata.figmaComponentData && (
                <copy-figma-button
                  data-component-id={constructId}
                  text-content={metadata.name}
                />
              )}

              <copy-markdown-button component-id={constructId} />
            </MetadataBlock>
          </section>
        )
      }
    </div>

    <div class="col">
      {
        metadata.componentExampleImage ? (
          <image-lightbox>
            <OptimizedImage
              src={metadata.componentExampleImage}
              alt={`${metadata.name} example`}
              class="wiki-image-preview"
            />
          </image-lightbox>
        ) : (
          <div class="wiki-image-placeholder" />
        )
      }
    </div>
  </div>

  {
    metadata.anatomy &&
      (metadata.anatomy.image ||
        (metadata.anatomy.table && metadata.anatomy.table.length > 0)) && (
        <section id="anatomy" class="p-section">
          <h2 id="anatomy"><a href="#anatomy" class="p-link--anchor-heading">Anatomy</a></h2>
          <div class="row--50-50">
            <div class="col">
              {metadata.anatomy.table && metadata.anatomy.table.length > 0 && (
                <div class="wiki-anatomy-list">
                  {[...metadata.anatomy.table]
                    .sort((a, b) => a.number - b.number)
                    .map((item) => (
                      <div class="wiki-anatomy-item">
                        <div class="wiki-anatomy-item-header">
                          <div class="wiki-anatomy-number">{item.number}</div>
                          <div class="wiki-anatomy-name">{item.name}</div>
                        </div>
                        <div class="wiki-anatomy-description">
                          <Fragment set:html={renderInlineMarkdown(item.description)} />
                        </div>
                      </div>
                    ))}
                </div>
              )}
            </div>

            <div class="col">
              {metadata.anatomy.image && (
                <image-lightbox>
                  <OptimizedImage
                    src={metadata.anatomy.image}
                    alt={`${metadata.name} anatomy`}
                    class="wiki-image-contain"
                  />
                </image-lightbox>
              )}
            </div>
          </div>
        </section>
      )
  }

  <div class="row--50-50 p-section">
    <div class="col">
      {
        hasUsage && (
          <section id="usage" class="u-text-max-width">
            <h2 id="usage"><a href="#usage" class="p-link--anchor-heading">Usage</a></h2>
            <Fragment set:html={usageHtml} />
          </section>
        )
      }

      {
        hasExamples && (
          <section id="examples" class="u-text-max-width">
            <h2 id="examples"><a href="#examples" class="p-link--anchor-heading">Examples</a></h2>
            <Fragment set:html={examplesHtml} />
          </section>
        )
      }

      {
        hasInteractions && (
          <section id="interactions" class="u-text-max-width">
            <h2 id="interactions"><a href="#interactions" class="p-link--anchor-heading">Interactions</a></h2>
            <Fragment set:html={interactionsHtml} />
          </section>
        )
      }
    </div>

    <div class="col"></div>
  </div>

  <div class="p-section">
    {
      ((metadata.properties && metadata.properties.length > 0) ||
        (metadata.childProperties && metadata.childProperties.length > 0)) && (
        <section id="properties" class="u-text-max-width">
          <h2 id="properties"><a href="#properties" class="p-link--anchor-heading">Properties</a></h2>

          {metadata.properties && metadata.properties.length > 0 && (
            <table aria-label="Properties" class="wiki-properties-table">
              <thead>
                <tr>
                  <th class="wiki-properties-name">Name</th>
                  <th class="wiki-properties-type">Type</th>
                  <th class="wiki-properties-required">Required</th>
                  <th class="wiki-properties-description">Description</th>
                  <th class="wiki-properties-constraint">Constraint</th>
                  <th class="wiki-properties-options">Options</th>
                  <th class="wiki-properties-default-option">Default option</th>
                </tr>
              </thead>
              <tbody>
                {metadata.properties.map((property) => (
                  <tr>
                    <td class="wiki-properties-name">{property.name}</td>
                    <td class="wiki-properties-type">{property.type}</td>
                    <td class="wiki-properties-required">
                      {property.required ? "Yes" : "No"}
                    </td>
                    <td class="wiki-properties-description">
                      <Fragment set:html={renderInlineMarkdown(property.description) || "-"} />
                    </td>
                    <td class="wiki-properties-constraint">
                      <Fragment set:html={renderInlineMarkdown(property.constraint) || "-"} />
                    </td>
                    <td class="wiki-properties-options">
                      {property.options && property.options.length > 0
                        ? property.options.join(", ")
                        : "-"}
                    </td>
                    <td class="wiki-properties-default-option">
                      {property.defaultOption || "-"}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}

          {metadata.childProperties && metadata.childProperties.length > 0 && (
            <div class="p-section--shallow">
              <h3 id="child-properties"><a href="#child-properties" class="p-link--anchor-heading">Child properties</a></h3>
              {metadata.childProperties.map((child) => (
                <>
                  <h4>{child.name}</h4>
                  <table
                    aria-label={`${child.name} properties`}
                    class="wiki-properties-table"
                  >
                    <thead>
                      <tr>
                        <th class="wiki-properties-name">Name</th>
                        <th class="wiki-properties-type">Type</th>
                        <th class="wiki-properties-required">Required</th>
                        <th class="wiki-properties-description">Description</th>
                        <th class="wiki-properties-constraint">Constraint</th>
                        <th class="wiki-properties-options">Options</th>
                        <th class="wiki-properties-default-option">
                          Default option
                        </th>
                      </tr>
                    </thead>
                    <tbody>
                      {child.properties.map((property) => (
                        <tr>
                          <td class="wiki-properties-name">{property.name}</td>
                          <td class="wiki-properties-type">{property.type}</td>
                          <td class="wiki-properties-required">
                            {property.required ? "Yes" : "No"}
                          </td>
                          <td class="wiki-properties-description">
                            <Fragment set:html={renderInlineMarkdown(property.description) || "-"} />
                          </td>
                          <td class="wiki-properties-constraint">
                            <Fragment set:html={renderInlineMarkdown(property.constraint) || "-"} />
                          </td>
                          <td class="wiki-properties-options">
                            {property.options && property.options.length > 0
                              ? property.options.join(", ")
                              : "-"}
                          </td>
                          <td class="wiki-properties-default-option">
                            {property.defaultOption || "-"}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </>
              ))}
            </div>
          )}
        </section>
      )
    }
  </div>

  <ChangeLogTable entries={metadata.changeLog ?? []} />
  <DecisionLogTable entries={metadata.decisionLog ?? []} />
  <MentionedInList entries={metadata.mentionedIn ?? []} tierPrefix={tierPrefix} />

  <script>
    import "../components/copyFigmaButton/copy-figma-button.ts";
    import "../components/copyMarkdownButton/copy-markdown-button.ts";
    import "../components/llmButton/llm-button.ts";
    import "../components/imageLightbox/image-lightbox.ts";
  </script>
</BaseLayout>
