---
interface Props {
  href: string;
}

const { href } = Astro.props;
---

<a href={href} target="_blank" rel="noopener noreferrer" class="wiki-chip">
  <img
    src="/logos/figma.svg"
    alt="Figma logo"
    class="wiki-chip__icon"
    width="16"
    height="16"
  />
  <span>Open in Figma</span>
</a>
