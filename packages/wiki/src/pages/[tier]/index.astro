---
import { getCollection } from "astro:content";
import { TIERS } from "@wiki/shared";
import { getFirstPageForTier } from "../../utils/first-page-for-tier";

export function getStaticPaths() {
  return TIERS.map((tier) => ({
    params: { tier: tier.toLowerCase() },
    props: { activeTier: tier },
  }));
}

const { activeTier } = Astro.props;

const allConcepts = await getCollection("concepts");
const allConstructs = await getCollection("constructs");

return Astro.redirect(
  getFirstPageForTier(activeTier, allConcepts, allConstructs),
  301,
);
---
