---
import { getCollection, getEntry } from "astro:content";
import FigmaLink from "../components/FigmaLink.astro";
import GithubLink from "../components/GithubLink.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { renderMarkdown, renderInlineMarkdown } from "../utils/render-markdown";

// Generate paths for all components
export async function getStaticPaths() {
  const components = await getCollection("components");

  return components.map((component: any) => ({
    params: { slug: component.id },
    props: { componentId: component.id },
  }));
}

const { componentId } = Astro.props;

// Get component metadata
const component = await getEntry("components", componentId);
const metadata = component.data;

// Render markdown sections
const descriptionHtml = renderMarkdown(metadata.description);
const usageHtml = renderMarkdown(metadata.usage);
const examplesHtml = renderMarkdown(metadata.examples);
const interactionsHtml = renderMarkdown(metadata.interactions);

const hasDescription = descriptionHtml.length > 0;
const hasUsage = usageHtml.length > 0;
const hasExamples = examplesHtml.length > 0;
const hasInteractions = interactionsHtml.length > 0;
---

<BaseLayout
  title={`${metadata.name} - Component Wiki`}
  currentSlug={componentId}
>
  <div slot="meta" class="p-table-of-contents">
    <div class="p-table-of-contents__section">
      <h2 class="p-table-of-contents__header">On this page</h2>
      <ul class="p-table-of-contents__list">
        <li class="p-table-of-contents__item">
          <a class="p-table-of-contents__link" href="#metadata">Metadata</a>
        </li>
        {
          hasDescription && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#description">
                Description
              </a>
            </li>
          )
        }
        {
          metadata.anatomy &&
            (metadata.anatomy.image ||
              (metadata.anatomy.table &&
                metadata.anatomy.table.length > 0)) && (
              <li class="p-table-of-contents__item">
                <a class="p-table-of-contents__link" href="#anatomy">
                  Anatomy
                </a>
              </li>
            )
        }
        {
          hasUsage && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#usage">
                Usage
              </a>
            </li>
          )
        }
        {
          hasExamples && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#examples">
                Examples
              </a>
            </li>
          )
        }
        {
          hasInteractions && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#interactions">
                Interactions
              </a>
            </li>
          )
        }
        {
          ((metadata.properties && metadata.properties.length > 0) ||
            (metadata.childProperties &&
              metadata.childProperties.length > 0)) && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#properties">
                Properties
              </a>
            </li>
          )
        }
        {
          metadata.changeLog && metadata.changeLog.length > 0 && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#changelog">
                Change log
              </a>
            </li>
          )
        }
        {
          metadata.decisionLog && metadata.decisionLog.length > 0 && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#decisionlog">
                Decision log
              </a>
            </li>
          )
        }
        {
          metadata.mentionedIn && metadata.mentionedIn.length > 0 && (
            <li class="p-table-of-contents__item">
              <a class="p-table-of-contents__link" href="#mentionedin">
                Mentioned in
              </a>
            </li>
          )
        }
      </ul>
    </div>
  </div>

  <div class="l-docs__title">
    <div class="p-strip is-shallow u-no-padding--bottom">
      <div class="u-fixed-width">
        <h1>{metadata.name}</h1>
      </div>
    </div>
  </div>

  <div class="row--50-50 p-section">
    <div class="col">
      {
        hasDescription && (
          <section id="description" class="u-text-max-width">
            <Fragment set:html={descriptionHtml} />

            <div class="metadata-list">
              <div class="metadata-item">
                <span class="metadata-key p-text--small-caps u-text--muted">
                  Type
                </span>
                <span class="metadata-value">{metadata.type}</span>
              </div>

              <div class="metadata-item">
                <span class="metadata-key p-text--small-caps u-text--muted">
                  Tier
                </span>
                <span class="metadata-value">{metadata.tiers}</span>
              </div>

              <div class="metadata-item">
                <span class="metadata-key p-text--small-caps u-text--muted">
                  Documentation Status
                </span>
                <span class="metadata-value">
                  {metadata.documentationStatus}
                </span>
              </div>

              <div class="metadata-item">
                <span class="metadata-key p-text--small-caps u-text--muted">
                  Last Edited
                </span>
                <span class="metadata-value">{new Date(metadata.lastEdited).toLocaleDateString("de-DE", { day: "2-digit", month: "2-digit", year: "numeric" })}</span>
              </div>

              <div class="metadata-chips">
                {metadata.figmaLink && <FigmaLink href={metadata.figmaLink} />}
                {metadata.codeLink && <GithubLink href={metadata.codeLink} />}
              </div>

              {metadata.figmaComponentData && (
                <copy-figma-button
                  data-component-id={componentId}
                  text-content={metadata.name}
                />
              )}

              <llm-button component-id={componentId} />

              <copy-markdown-button component-id={componentId} />
            </div>
          </section>
        )
      }
    </div>

    <div class="col">
      {
        metadata.componentExampleImage ? (
          <image-lightbox>
            <img
              src={`/${metadata.componentExampleImage}`}
              alt={`${metadata.name} example`}
              style="width: 100%; height: 500px; object-fit: contain; background-color: #F7F7F7;"
            />
          </image-lightbox>
        ) : (
          <div style="width: 100%; height: 500px; background-color: #F7F7F7;" />
        )
      }
    </div>
  </div>

  {
    metadata.anatomy &&
      (metadata.anatomy.image ||
        (metadata.anatomy.table && metadata.anatomy.table.length > 0)) && (
        <section id="anatomy" class="p-section">
          <h2>Anatomy</h2>
          <div class="row--50-50">
            <div class="col">
              {metadata.anatomy.table && metadata.anatomy.table.length > 0 && (
                <div class="anatomy-list">
                  {[...metadata.anatomy.table]
                    .sort((a, b) => a.number - b.number)
                    .map((item) => (
                      <div class="anatomy-item">
                        <div class="anatomy-item-header">
                          <div class="anatomy-number">{item.number}</div>
                          <div class="anatomy-name">{item.name}</div>
                        </div>
                        <div class="anatomy-description">
                          <Fragment set:html={renderInlineMarkdown(item.description)} />
                        </div>
                      </div>
                    ))}
                </div>
              )}
            </div>

            <div class="col">
              {metadata.anatomy.image && (
                <image-lightbox>
                  <img
                    src={`/${metadata.anatomy.image}`}
                    alt={`${metadata.name} anatomy`}
                    style="width: 100%; height: auto; object-fit: contain;"
                  />
                </image-lightbox>
              )}
            </div>
          </div>
        </section>
      )
  }

  <div class="row--50-50 p-section">
    <div class="col">
      {
        hasUsage && (
          <section id="usage" class="u-text-max-width">
            <h2>Usage</h2>
            <Fragment set:html={usageHtml} />
          </section>
        )
      }

      {
        hasExamples && (
          <section id="examples" class="u-text-max-width">
            <h2>Examples</h2>
            <Fragment set:html={examplesHtml} />
          </section>
        )
      }

      {
        hasInteractions && (
          <section id="interactions" class="u-text-max-width">
            <h2>Interactions</h2>
            <Fragment set:html={interactionsHtml} />
          </section>
        )
      }
    </div>

    <div class="col"></div>
  </div>

  <div class="p-section">
    {
      ((metadata.properties && metadata.properties.length > 0) ||
        (metadata.childProperties && metadata.childProperties.length > 0)) && (
        <section id="properties" class="u-text-max-width">
          <h2>Properties</h2>

          {metadata.properties && metadata.properties.length > 0 && (
            <table aria-label="Properties" class="properties-table">
              <thead>
                <tr>
                  <th class="properties-name">Name</th>
                  <th class="properties-type">Type</th>
                  <th class="properties-required">Required</th>
                  <th class="properties-description">Description</th>
                  <th class="properties-constraint">Constraint</th>
                  <th class="properties-options">Options</th>
                  <th class="properties-default-option">Default option</th>
                </tr>
              </thead>
              <tbody>
                {metadata.properties.map((property) => (
                  <tr>
                    <td class="properties-name">{property.name}</td>
                    <td class="properties-type">{property.type}</td>
                    <td class="properties-required">
                      {property.required ? "Yes" : "No"}
                    </td>
                    <td class="properties-description">
                      <Fragment set:html={renderInlineMarkdown(property.description) || "-"} />
                    </td>
                    <td class="properties-constraint">
                      <Fragment set:html={renderInlineMarkdown(property.constraint) || "-"} />
                    </td>
                    <td class="properties-options">
                      {property.options && property.options.length > 0
                        ? property.options.join(", ")
                        : "-"}
                    </td>
                    <td class="properties-default-option">
                      {property.defaultOption || "-"}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}

          {metadata.childProperties && metadata.childProperties.length > 0 && (
            <div class="p-section--shallow">
              <h3>Child properties</h3>
              {metadata.childProperties.map((child) => (
                <>
                  <h4>{child.name}</h4>
                  <table
                    aria-label={`${child.name} properties`}
                    class="properties-table"
                  >
                    <thead>
                      <tr>
                        <th class="properties-name">Name</th>
                        <th class="properties-type">Type</th>
                        <th class="properties-required">Required</th>
                        <th class="properties-description">Description</th>
                        <th class="properties-constraint">Constraint</th>
                        <th class="properties-options">Options</th>
                        <th class="properties-default-option">
                          Default option
                        </th>
                      </tr>
                    </thead>
                    <tbody>
                      {child.properties.map((property) => (
                        <tr>
                          <td class="properties-name">{property.name}</td>
                          <td class="properties-type">{property.type}</td>
                          <td class="properties-required">
                            {property.required ? "Yes" : "No"}
                          </td>
                          <td class="properties-description">
                            <Fragment set:html={renderInlineMarkdown(property.description) || "-"} />
                          </td>
                          <td class="properties-constraint">
                            <Fragment set:html={renderInlineMarkdown(property.constraint) || "-"} />
                          </td>
                          <td class="properties-options">
                            {property.options && property.options.length > 0
                              ? property.options.join(", ")
                              : "-"}
                          </td>
                          <td class="properties-default-option">
                            {property.defaultOption || "-"}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </>
              ))}
            </div>
          )}
        </section>
      )
    }
  </div>

  <div class="p-section">
    {
      metadata.changeLog && metadata.changeLog.length > 0 && (
        <section id="changelog" class="u-text-max-width">
          <h2>Change log</h2>
          <table aria-label="Change log" class="changelog-table">
            <thead>
              <tr>
                <th class="changelog-who">Who</th>
                <th class="changelog-when">When</th>
                <th class="changelog-what">What</th>
              </tr>
            </thead>
            <tbody>
              {metadata.changeLog.map((entry) => (
                <tr>
                  <td class="changelog-who">{entry.who}</td>
                  <td class="changelog-when">
                    {new Date(entry.when).toLocaleDateString("de-AT", {
                      year: "numeric",
                      month: "2-digit",
                      day: "2-digit",
                    })}
                  </td>
                  <td class="changelog-what"><Fragment set:html={renderInlineMarkdown(entry.what)} /></td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      )
    }
  </div>

  <div class="p-section">
    {
      metadata.decisionLog && metadata.decisionLog.length > 0 && (
        <section id="decisionlog" class="u-text-max-width">
          <h2>Decision log</h2>
          <table aria-label="Decision log" class="decisionlog-table">
            <thead>
              <tr>
                <th class="decisionlog-where">Where</th>
                <th class="decisionlog-decision">Decision made</th>
                <th class="decisionlog-link">Link</th>
              </tr>
            </thead>
            <tbody>
              {metadata.decisionLog.map((entry) => (
                <tr>
                  <td class="decisionlog-where"><Fragment set:html={renderInlineMarkdown(entry.where)} /></td>
                  <td class="decisionlog-decision"><Fragment set:html={renderInlineMarkdown(entry.decisionMade)} /></td>
                  <td class="decisionlog-link">
                    {entry.link ? (
                      <a
                        href={entry.link}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        View
                      </a>
                    ) : (
                      "-"
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      )
    }
  </div>

  {
    metadata.mentionedIn && metadata.mentionedIn.length > 0 && (
      <div class="p-section">
        <section id="mentionedin" class="u-text-max-width">
          <h2>Mentioned in</h2>
          <ul class="p-list">
            {metadata.mentionedIn.map((entry) => (
              <li class="p-list__item">
                <a href={`/${entry.slug}`}>{entry.name}</a>
              </li>
            ))}
          </ul>
        </section>
      </div>
    )
  }

  <style>
    .metadata-list {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem 2rem;
      align-items: center;
    }

    .metadata-item {
      display: flex;
      flex-direction: column;
    }

    .metadata-key {
      margin: 0;
    }

    .metadata-value {
      margin: 0;
    }

    .metadata-chips {
      display: flex;
      gap: 1.5rem;
      align-items: center;
    }

    .changelog-table {
      table-layout: fixed;
      width: 100%;
    }

    .changelog-who {
      width: 200px;
    }

    .changelog-when {
      width: 150px;
    }

    .changelog-what {
      width: auto;
    }

    .decisionlog-table {
      table-layout: fixed;
      width: 100%;
    }

    .decisionlog-where {
      width: 200px;
    }

    .decisionlog-decision {
      width: auto;
    }

    .decisionlog-link {
      width: 100px;
    }

    .properties-table {
      table-layout: fixed;
      width: 100%;
    }

    .properties-name {
      width: 150px;
    }

    .properties-type {
      width: 120px;
    }

    .properties-required {
      width: 100px;
    }

    .properties-description {
      width: auto;
      min-width: 200px;
    }

    .properties-constraint {
      width: 150px;
    }

    .properties-options {
      width: 180px;
    }

    .properties-default-option {
      width: 120px;
    }

    .anatomy-list {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .anatomy-item {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .anatomy-item-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .anatomy-number {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background-color: #cf0075;
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.875rem;
      font-weight: 500;
      flex-shrink: 0;
    }

    .anatomy-name {
      font-weight: bold;
    }

    .anatomy-description {
      margin-left: calc(24px + 0.75rem);
    }
  </style>

  <script>
    import "../components/copyFigmaButton/copy-figma-button.js";
    import "../components/copyMarkdownButton/copy-markdown-button.js";
    import "../components/llmButton/llm-button.js";
    import "../components/imageLightbox/image-lightbox.js";
  </script>
</BaseLayout>
